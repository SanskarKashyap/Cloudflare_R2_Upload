{
  "name": "cloudflare_r2_upload",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "upload:batch": "tsc && node --no-warnings --enable-source-maps -r dotenv/config ./build/app.js",
    "esbuild": "esbuild --bundle"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "md5": "^2.3.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/md5": "^2.3.2",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.19.43",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.14",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
